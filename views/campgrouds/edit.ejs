<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Camp</title>
</head>
<body>
    <h1>Edit Campgrounds</h1>
    <form action="/campgrounds/<%=camp._id%>?_method=PUT" method="POST">
        <div>
            <label for="title">Title</label>
            <input type="text" id="title" name="campground[title]" value="<%= camp.title%>">
        </div>
        <br>
        <div>
            <label for="location">Location</label>
            <input type="text" id="location" name="campground[location]" value="<%= camp.location%>">
        </div>
        <br>
        <button>Update Campground</button>
    </form>
    <br>
    <a href="/campgrounds/<%= camp._id%>">Back to Campground </a>
</body>
</html>
